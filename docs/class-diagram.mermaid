classDiagram
    direction TB

    class ProviderRecord {
        +int64 ID
        +string Name
        +string Slug
        +string Endpoint
        +[]byte EncryptedKey
        +bool IsDefault
        +bool Enabled
        +string CreatedAt
        +string UpdatedAt
    }

    class ModelMappingRecord {
        +int64 ID
        +string External
        +string ProviderID
        +string RealModel
        +string CreatedAt
    }

    class AuditLogRecord {
        +int64 ID
        +string Action
        +string TargetType
        +string TargetID
        +string Detail
        +string CreatedAt
    }

    class RoutingRule {
        +int64 ID
        +string ProviderID
        +string StartTime
        +string EndTime
        +string DaysOfWeek
        +string Timezone
        +bool Enabled
    }

    class ProviderStore {
        -*sql.DB db
        -[]byte kek
        +NewProviderStore(db, kek) *ProviderStore
        +ListProviders() []ProviderRecord
        +GetProvider(slug) ProviderRecord
        +CreateProvider(name,slug,endpoint,apiKey,isDefault) ProviderRecord
        +UpdateProvider(slug,updates) ProviderRecord
        +DeleteProvider(slug) error
        +SetDefaultProvider(slug) error
        +ListMappings() []ModelMappingRecord
        +CreateMapping(external,providerID,realModel) ModelMappingRecord
        +UpdateMapping(id,updates) error
        +DeleteMapping(id) error
        +ListRoutingRules() []RoutingRule
        +CreateRoutingRule(rule) error
        +UpdateRoutingRule(id,updates) error
        +DeleteRoutingRule(id) error
        +ListAuditLogs(page,limit) []AuditLogRecord
        +WriteAudit(action,targetType,targetID,detail)
        +BuildProviderTable() ProviderTable
        +SeedFromConfig(cfg) error
    }

    class ProviderTable {
        +map~string~ProviderEntry Providers
        +map~string~map~string~string Mappings
        +string Default
    }

    class ProviderEntry {
        +string Slug
        +string Endpoint
        +string APIKey
    }

    class Router {
        -*sql.DB db
        -ProviderStore store
        -atomic.Value table
        +NewRouter(db,store) *Router
        +ResolveProvider(now) Provider
        +RewriteModel(external,providerID) string
        +Reload() error
    }

    class ProviderResult {
        +string ID
        +string Endpoint
        +string APIKey
    }

    class AdminHandler {
        -*sql.DB DB
        -ProviderStore Store
        -Router Router
        +HandleListProviders()
        +HandleCreateProvider()
        +HandleUpdateProvider()
        +HandleDeleteProvider()
        +HandleListMappings()
        +HandleCreateMapping()
        +HandleUpdateMapping()
        +HandleDeleteMapping()
        +HandleListRoutingRules()
        +HandleCreateRoutingRule()
        +HandleUpdateRoutingRule()
        +HandleDeleteRoutingRule()
        +HandleListAuditLogs()
    }

    class SecurityPackage {
        +DeriveKEK() []byte
        +Encrypt(plaintext,key) []byte
        +Decrypt(ciphertext,key) string
        +MaskKey(key) string
    }

    class Config {
        +[]ProviderConfig Providers
        +[]ModelMapping ModelMappings
    }

    ProviderStore ..> ProviderRecord : CRUD
    ProviderStore ..> ModelMappingRecord : CRUD
    ProviderStore ..> AuditLogRecord : writes
    ProviderStore ..> RoutingRule : CRUD
    ProviderStore ..> SecurityPackage : encrypt/decrypt
    ProviderStore --> ProviderTable : BuildProviderTable()
    ProviderStore ..> Config : SeedFromConfig()
    Router --> ProviderStore : reads via
    Router --> ProviderTable : atomic.Value
    Router --> ProviderResult : returns
    AdminHandler --> ProviderStore : CRUD via
    AdminHandler --> Router : Reload()
