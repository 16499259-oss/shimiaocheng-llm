classDiagram
    class Config {
        +ServerConfig Server
        +DatabaseConfig Database
        +ProxyConfig Proxy
        +ProviderQuotaConfig ProviderQuota
    }
    class ProviderQuotaConfig {
        +float64 DefaultTokenLowRatio
        +float64 DefaultCallLowRatio
    }
    class ProviderRecord {
        +int64 ID
        +string Slug
        +int64 MonthlyTokenLimit
        +int64 MonthlyCallLimit
        +float64 MonthlyTokenLowRatio
        +float64 MonthlyCallLowRatio
    }
    class ProviderWithMaskedKey {
        +float64 MonthlyTokenLowRatio
        +float64 MonthlyCallLowRatio
    }
    class ProviderUsageView {
        +int64 MonthlyTokenLimit
        +int64 MonthlyCallLimit
        +bool TokenLow
        +bool CallLow
    }
    class ProviderStore {
        +CreateProvider(... monthlyTokenLowRatio, monthlyCallLowRatio float64) *ProviderRecord
        +UpdateProvider(slug, updates map) *ProviderRecord
        +ListProviders() []ProviderRecord
        +GetProvider(slug) *ProviderRecord
        +BuildMaskedProviders() []ProviderWithMaskedKey
        +SeedFromConfig(cfg)
    }
    class ProviderUsageModule {
        +IsLowBalance(used, limit int64, ratio float64) bool
        +BuildProviderUsageView(p, used, window, globalTokenRatio, globalCallRatio float64) ProviderUsageView
    }
    class Handler {
        +Config *config.Config
        +globalTokenLowRatio() float64
        +globalCallLowRatio() float64
    }

    Config *-- ProviderQuotaConfig
    ProviderRecord "1" ..> "1" ProviderUsageView : BuildProviderUsageView
    ProviderWithMaskedKey --|> ProviderRecord : 含同名字段
    ProviderStore ..> ProviderRecord : reads / writes
    ProviderStore ..> ProviderWithMaskedKey : BuildMaskedProviders
    Handler ..> ProviderStore : ListProviders / Create / Update
    Handler ..> ProviderUsageModule : BuildProviderUsageView(...)
    ProviderUsageModule ..> ProviderRecord : effectiveRatio 解析
