classDiagram
    %% ===== 数据模型层 (internal/models) =====
    class ProviderRecord {
        +int64 ID
        +string Name
        +string Slug
        +string Endpoint
        +[]byte EncryptedKey
        +bool IsDefault
        +bool Enabled
        +bool AllowPassthrough
        +string AuthHeader
        +string AuthScheme
        +string ExtraHeaders
        +int64 MonthlyTokenLimit
        +int64 MonthlyCallLimit
        +string CreatedAt
        +string UpdatedAt
    }

    class ProviderWithMaskedKey {
        +int64 ID
        +string Name
        +string Slug
        +string Endpoint
        +string MaskedKey
        +bool IsDefault
        +bool Enabled
        +bool AllowPassthrough
        +string AuthHeader
        +string AuthScheme
        +string ExtraHeaders
        +int64 MonthlyTokenLimit
        +int64 MonthlyCallLimit
        +string CreatedAt
        +string UpdatedAt
    }
    ProviderRecord <|-- ProviderWithMaskedKey

    class ProviderMonthlyUsage {
        +string Slug
        +int64 TokenUsed
        +int64 CallUsed
    }

    class ProviderUsageView {
        +string Slug
        +string Name
        +int64 MonthlyTokenLimit
        +int64 MonthlyCallLimit
        +int64 TokenUsed
        +int64 TokenRemaining
        +bool TokenUnlimited
        +int64 CallUsed
        +int64 CallRemaining
        +bool CallUnlimited
        +string WindowStart
        +bool TokenLow
        +bool CallLow
    }
    ProviderMonthlyUsage ..> ProviderUsageView : BuildProviderUsageView(p, used, window)

    class ModelsUsage {
        <<package functions>>
        +RollingWindowStart() string
        +AggregateProviderUsage(db, windowStart) map~string,ProviderMonthlyUsage~
        +GetProviderUsage(db, slug, windowStart) *ProviderMonthlyUsage
        +IsLowBalance(used, limit) bool
        +BuildProviderUsageView(p, used, window) ProviderUsageView
    }

    %% ===== 存储层 (internal/provider) =====
    class ProviderStore {
        -db *sql.DB
        -kek []byte
        +ListProviders() []ProviderRecord
        +GetProvider(slug) *ProviderRecord
        +CreateProvider(name, slug, endpoint, apiKey, isDefault, allowPassthrough, authHeader, authScheme, extraHeaders, monthlyTokenLimit, monthlyCallLimit) *ProviderRecord
        +UpdateProvider(slug, updates) *ProviderRecord
        +BuildMaskedProviders() []ProviderWithMaskedKey
        +SeedFromConfig(cfg) error
    }
    ProviderStore --> ProviderRecord : 读写
    ProviderStore --> ProviderWithMaskedKey : 构造

    %% ===== 后端 API 层 (internal/admin) =====
    class AdminHandler {
        +DB *sql.DB
        +ProviderStore *ProviderStore
        +HandleListProviderUsage(w, r)
        +HandleGetProviderUsage(w, r)
        +ServeProviderUsagePage(w, r)
    }
    AdminHandler --> ProviderStore : 取 providers + 限额
    AdminHandler --> ModelsUsage : 调聚合/低余额
    AdminHandler ..> ProviderUsageView : 返回 data

    %% ===== 前端 (web/admin) =====
    class FrontendState {
        +providerMap: slug->name
        +usageMap: slug->ProviderUsageView
        +loadProviders()
        +fetchProviderUsage(slug)
        +loadProviderUsage()
        +formatToken(n)
        +renderUsageCell(used, limit, low)
    }
    FrontendState ..> ProviderUsageView : 消费 data
    FrontendState ..> AdminHandler : GET /api/provider-usage , /api/providers/{slug}/usage
