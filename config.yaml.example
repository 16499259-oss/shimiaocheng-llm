# LLM API Gateway — 配置文件
server:
  listen_addr: "127.0.0.1:8080"   # 仅监听本地（Nginx 反代）
  read_timeout: 120s
  write_timeout: 300s

database:
  path: "./llm_gateway.db"        # SQLite 数据库文件路径

api:
  zhipu_endpoint: "https://api.zhipuai.cn/api/paas/v4/chat/completions"
  zhipu_api_key: ""               # 智谱 API Key（也可通过环境变量 ZHIPU_API_KEY 设置）

# 多上游配置：网关按「时间段」自动路由到不同 provider。
# 每个 provider 的 Key 仅由对应 api_key_env 环境变量在启动时注入内存（绝不落盘，见 ADR-0002）。
providers:
  - id: "zhipu"
    endpoint: "https://api.zhipuai.cn/api/paas/v4/chat/completions"
    api_key_env: "ZHIPU_API_KEY"
    is_default: true
  - id: "openai"
    endpoint: "https://api.openai.com/v1/chat/completions"   # 部署时可改；绝不硬编码到代码逻辑外
    api_key_env: "OPENAI_API_KEY"
    is_default: false

# 外部（用户侧）模型名 -> 各 provider 真实模型名 的映射。
# 缺失映射时按 passthrough 透传原 external 名，不报错。
# 主理人决策：默认模型 glm-5.2 也进映射表（zhipu 用 glm-5.2，openai 用 gpt-4o）。
model_mappings:
  - external: "glm-5.2"
    per_provider:
      zhipu: "glm-5.2"
      openai: "gpt-4o"
  - external: "glm-4-plus"
    per_provider:
      zhipu: "glm-4-plus"
      openai: "gpt-4o"

auth:
  sub_key_salt: "llm-gateway-salt-2025"   # 子 Key 生成盐值（请修改为随机字符串）
  session_expire_hours: 24                 # Admin 会话过期时间（小时）

quota:
  default_5h_limit: 100           # 默认 5h 窗口调用次数上限
  default_total_limit: 10000      # 默认账户总调用次数上限
  reset_interval_hours: 5         # 5h 窗口重置间隔

# 请求体超限策略：
#   trim（默认）— 超过用户「单次请求上限」时自动裁剪历史对话（保留 system + 最近轮次）后转发，不再 413；
#   off         — 恢复旧行为：超过用户上限直接返回 413。
# 注意：无论哪种，超过 nginx 32MB 绝对天花板仍会被拒（413）。
compaction: "trim"

# 调试开关：
#   false（默认）— 生产安全，JSON 解析失败时只记录错误与长度，不打印请求体（避免泄露用户对话内容）；
#   true          — 解析失败时额外把原始请求体 dump 到日志，便于排查畸形客户端。
debug: false

# 通配透传总开关（MCP / 任意上游路径）：
#   passthrough_enabled: false（默认）— /v1/passthrough/ 端点完全关闭，任何请求返回 403 passthrough_disabled；
#   passthrough_enabled: true  — 全局放行；但仍需目标 provider 的 allow_passthrough=true 才真正转发（双开关，纵深防御）。
# 详见 docs/design-mcp-passthrough.md。建议为 MCP 用途单独新建 provider（endpoint 填 base URL，如 https://api.anthropic.com）。
proxy:
  passthrough_enabled: false

# 上游低余额阈值（全局默认，比例值；0.10 =「剩余 < 10% 时标红」）。
# token 与 调用次数 各自独立；每 provider 可在管理面板覆盖（填 0 / 留空 = 继承此处全局默认）。
# 仅在 config.yaml 配置，不提供 UI 编辑入口。
#
# cycle_start_date: 固定 30 天周期的起始锚点（"2006-01-02" DATE 格式）。
# 新建 provider 默认当天，可在管理面板编辑；存量迁移取 DATE(created_at)。
provider_quota:
  default_token_low_ratio: 0.10
  default_call_low_ratio: 0.10
